layout {
  pane split_direction="vertical" {
    pane {
      edit "."
      focus true
      size "60%"
      borderless true
    }
    pane stacked=true {
      pane {
        name "LazyGit"
        command "lazygit"
      }
      pane {
        name "Terminal"
      }
    }
  }
  pane borderless=true size=1 {
    plugin location="zellij:compact-bar" 
  }
}
